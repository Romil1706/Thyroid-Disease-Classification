import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.neighbors import KNeighborsClassifier
from sklearn.metrics import accuracy_score
df = pd.read_csv("/content/thyroidDF.csv")

#EDA
print("Data Description\n",df.describe())
print("Rows of data before cleaning",len(df))

#statistical analysis
print("Statistical Analysis\n")
num_df = df.select_dtypes(include=['number'])
print("Mean:\n", num_df.mean())
print("\nMedian:\n", num_df.median())
print("\nMode:\n", num_df.mode().iloc[0])
print("\nStandard Deviation:\n", num_df.std())
print("\nVariance:\n", num_df.var())

#Skewness and kurtosis before cleaning data
X_before = df.select_dtypes(include=['number'])
print("\nSKEWNESS AND KURTOSIS BEFORE CLEANING")
print("Skewness:\n", X_before.skew())
print("\nKurtosis:\n", X_before.kurtosis())

#Data processing
df = df.drop(columns=['patient_id'], errors='ignore')
df.fillna(df.mean(numeric_only=True), inplace=True)
df['target']=df['target'].str.split('|').str[0]
df['target'] = df['target'].replace({
    '-': 'No disease',
    'A': 'Hyperthyroidism', 'B': 'Hyperthyroidism', 'C': 'Hyperthyroidism', 'D': 'Hyperthyroidism',
    'E': 'Hypothyroidism', 'F': 'Hypothyroidism', 'G': 'Hypothyroidism', 'H': 'Hypothyroidism'
})
# Target drop rules matching previous workflow requirements
df.dropna(subset=['target'], inplace=True)
x=df.select_dtypes(include=['number']).drop(columns=['target'], errors='ignore')
y=df['target']
df.loc[(df['age'] < 0) | (df['age'] > 120), 'age'] = np.nan
df['age'].fillna(df['age'].mean(), inplace=True)
print("\nAfter CLEANING")
print("Skewness:\n", x.skew())
print("\nKurtosis:\n", x.kurtosis())
print("Rows after cleaning",len(df))


#visualisation
features=list(x.columns)
skew_before = X_before[features].skew().values
skew_after = x.skew().values
plt.subplot(2, 1, 1)
plt.plot(features, skew_before, marker='o', label='Before')
plt.plot(features, skew_after, marker='o', label='After')
plt.title("Skewness Comparison")
plt.xlabel("Features")
plt.ylabel("Skewness")
plt.legend()
features=list(x.columns)
kurt_before = X_before[features].kurtosis().values
kurt_after = x.kurtosis().values
plt.subplot(3, 1, 3)
plt.plot(features, kurt_before, marker='o', label='Before')
plt.plot(features, kurt_after, marker='o', label='After')
plt.title("Kurtosis Comparison")
plt.xlabel("Features")
plt.ylabel("Kurtosis")
plt.legend()

#detecting outliers
num_df = df.select_dtypes(include=['number'])
for col in num_df.columns:
    Q1 = num_df[col].quantile(0.25)
    Q3 = num_df[col].quantile(0.75)
    IQR = Q3 - Q1
    lower = Q1 - 1.5 * IQR
    upper = Q3 + 1.5 * IQR
    outliers = df[(df[col] < lower) | (df[col] > upper)]
    print(f"\nColumn: {col}")
    print("Number of outliers:", len(outliers))

plt.figure(figsize=(10,5))
df.boxplot(rot=45)
plt.title("Boxplot for Outlier Detection")
plt.show()

#modeling
x_train,x_test,y_train,y_test=train_test_split(x,y,test_size=0.2,random_state=42)
model=KNeighborsClassifier(n_neighbors=3)
model.fit(x_train,y_train)
y_pred = model.predict(x_test)

#Accuracy
accuracy = accuracy_score(y_test, y_pred)
print("\nAccuracy:\n", accuracy*100, "%")

#Check predictions
print("\nActual:", y_test.values[:10])
print("\nPredicted:", y_pred[:10])
